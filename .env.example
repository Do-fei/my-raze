# =============================================================================
# my-raze — environment variables (template)
# Copy to `.env` and fill in real values. `.env` is gitignored per developer.
#
# NOTE: This is the Phase-0 shape. Phase 1 (security hardening) will reshape
# this file: API-key encryption keys, operator-managed master keys, Stripe
# subscription billing, and KMS/env dual key-providers will be added.
# =============================================================================

# --- Runtime ------------------------------------------------------------------
# `development` enables Vite middleware mode. Anything else is treated as prod.
NODE_ENV=development
# Port the unified Express + Vite server listens on.
# If busy, the app currently auto-discovers the next free port (to be tightened
# in Phase 5 — silent port-shift in prod is a known footgun).
PORT=3000

# --- Database -----------------------------------------------------------------
# MySQL 8 connection string. Local dev uses the docker container created by
# `docker run -d --name my-raze-mysql -e MYSQL_ROOT_PASSWORD=devpass \
#   -e MYSQL_DATABASE=myraze -p 3306:3306 mysql:8`.
DATABASE_URL=mysql://root:devpass@127.0.0.1:3306/myraze

# --- Auth ---------------------------------------------------------------------
# Cookie/JWT signing secret. MUST be a random ≥32-char string in production.
# Generate with: openssl rand -hex 32
# Phase 1 will add fail-fast at boot if length < 32.
JWT_SECRET=change-me-locally-then-rotate-in-production

# --- App identity (Manus OAuth — to be replaced in Phase 1) -------------------
# These wire the app to the Manus-hosted OAuth + storage proxy used by the
# original MVP. They will be replaced with self-hostable equivalents in Phase 1.
VITE_APP_ID=my-raze-dev
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# --- Built-in Forge storage proxy (to be replaced with S3/local in Phase 1) --
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
