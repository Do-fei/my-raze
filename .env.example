# =============================================================================
# my-raze — environment variables (template)
# Copy to `.env` and fill in real values. `.env` is gitignored per developer.
#
# Auth: ADR 0006 (Better-Auth + email magic-link). Phase 1b-ii.1.
# =============================================================================

# --- Runtime ------------------------------------------------------------------
# `development` enables Vite middleware mode. Anything else is treated as prod.
NODE_ENV=development
# Port the unified Express + Vite server listens on.
PORT=3000

# --- Database -----------------------------------------------------------------
# MySQL 8 connection string. Local dev uses the docker container created by
# `docker run -d --name my-raze-mysql -e MYSQL_ROOT_PASSWORD=devpass \
#   -e MYSQL_DATABASE=myraze -p 3306:3306 mysql:8`.
DATABASE_URL=mysql://root:devpass@127.0.0.1:3306/myraze

# --- Auth ---------------------------------------------------------------------
# Cookie/JWT signing secret. MUST be a random ≥32-char string in production.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-locally-then-rotate-in-production

# Master secret used to encrypt per-user BYOK API keys at rest
# (`server/_core/encryption.ts`). MUST be ≥32 chars and MUST be different
# from JWT_SECRET. Generate a SECOND random hex with: openssl rand -hex 32
KEY_ENCRYPTION_KEY=change-me-to-a-different-secret-than-jwt

# (Legacy) If set, this openId is auto-promoted to admin on first login.
# OWNER_OPEN_ID=

# --- Email (Phase 1b-ii.1 / ADR 0006) ----------------------------------------
# In production, you MUST configure either Resend OR SMTP. In dev, emails are
# printed to stdout if neither is set (StdoutDriver).
#
# Option A — Resend (default driver):
# RESEND_API_KEY=re_...
#
# Option B — SMTP:
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-user
# SMTP_PASS=your-pass
#
# Sender address (required in production):
# EMAIL_FROM=My App <noreply@example.com>

# --- Built-in Forge storage proxy (to be replaced with S3/local in Phase 1) --
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# --- Operator-managed AI provider keys (Phase 1b-i / ADR 0002) ----------------
# These are the keys used to serve subscription-tier users (the default).
# Users who opt into BYOK in Settings shadow these on a per-key basis.
OPERATOR_OPENROUTER_KEY=
OPERATOR_FAL_KEY=
OPERATOR_ELEVENLABS_KEY=
OPERATOR_FISH_AUDIO_KEY=
OPERATOR_OPENAI_KEY=
